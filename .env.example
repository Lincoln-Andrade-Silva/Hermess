# === Supabase / Postgres ===
# Conexão direta (porta 5432) para migrations. Runtime serverless: use a Transaction Pooler (6543).
# Se a senha tiver caracteres especiais (!, @, #...), faça URL-encode (ex: "!" -> "%21").
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# === Supabase Auth / Storage (client) ===
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[SUPABASE-PUBLISHABLE-OR-ANON-KEY]"

# === Server-only ===
# service_role (secret). Necessária a partir da Fase 1. NUNCA expor no client.
SUPABASE_SERVICE_ROLE_KEY="[SUPABASE-SERVICE-ROLE-KEY]"

# Credenciais do Mercado Pago NÃO vão aqui: ficam no banco, editáveis
# em Configurações > Pagamento (Fase 11).

# SMTP (Gmail) para e-mails transacionais
SMTP_USER=
SMTP_PASS=
